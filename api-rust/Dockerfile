# syntax=docker/dockerfile:1.6
#
# ---- Builder ------------------------------------------------------------
# Compiles the Rust API for linux/amd64 with target-cpu=haswell to match the
# Mac Mini Late 2014 test host. AVX2 is enabled in the kernel; LTO and a
# single codegen unit produce a tight, inlined binary with the AVX2 loop
# folded into the IVF dispatcher.
FROM rust:1.83-slim-bookworm AS build
RUN apt-get update && \
    apt-get install -y --no-install-recommends ca-certificates && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /src
COPY api-rust/Cargo.toml api-rust/Cargo.lock* ./
COPY api-rust/src ./src

ENV CARGO_TERM_COLOR=always \
    RUSTFLAGS="-C target-cpu=haswell -C target-feature=+avx2,+fma"
RUN cargo build --release --locked --bin api || cargo build --release --bin api

# ---- Runtime ------------------------------------------------------------
# Slim runtime image. Carries the compiled binary plus the pre-built index
# (generated by `make resources` outside Docker) and the MCC risk table.
FROM debian:bookworm-slim
RUN apt-get update && \
    apt-get install -y --no-install-recommends ca-certificates && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY --from=build /src/target/release/api /app/api
COPY build_resources/index.bin /app/index.bin
COPY build_resources/mcc_risk.json /app/mcc_risk.json

ENV INDEX_PATH=/app/index.bin \
    MCC_RISK_PATH=/app/mcc_risk.json \
    UDS_PATH=/sockets/api.sock \
    IVF_NPROBE=1 \
    IOURING_QD=4096 \
    ACCEPT_SQES=256 \
    BACKLOG=4096 \
    MAX_CONNS=1024 \
    WORKERS=2

ENTRYPOINT ["/app/api"]
