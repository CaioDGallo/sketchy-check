# syntax=docker/dockerfile:1.6

# ---- Builder ------------------------------------------------------------
# Compiles the Go API binary with cgo enabled for the AVX2 distance kernel.
# Targets linux/amd64 because the Mac Mini Late 2014 test host is Haswell.
FROM golang:1.23-bookworm AS build
RUN apt-get update && \
    apt-get install -y --no-install-recommends build-essential ca-certificates && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /src
COPY api/go.mod ./
# go.sum may not exist when there are no third-party deps; mod download handles its absence.
RUN go mod download

COPY api/ ./
ENV CGO_ENABLED=1 \
    GOFLAGS="-trimpath" \
    GOOS=linux \
    GOARCH=amd64
RUN go build -ldflags="-s -w" -o /api ./cmd/api

# ---- Runtime ------------------------------------------------------------
# Slim runtime image. Carries the compiled binary plus the pre-built index
# (generated by `make resources` outside Docker) and the MCC risk table.
FROM debian:bookworm-slim
RUN apt-get update && \
    apt-get install -y --no-install-recommends ca-certificates && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY --from=build /api /app/api
COPY build_resources/index.bin /app/index.bin
COPY build_resources/mcc_risk.json /app/mcc_risk.json

ENV INDEX_PATH=/app/index.bin \
    MCC_RISK_PATH=/app/mcc_risk.json \
    UDS_PATH=/sockets/api.sock \
    IVF_NPROBE=1 \
    GOGC=off \
    GOMEMLIMIT=140MiB \
    GOMAXPROCS=2

ENTRYPOINT ["/app/api"]
